# Required: Claude API key for extraction (Haiku) and chat/interpret (Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: rejestr.io API key for KRS/financial data
# Without this, the finance phase will be skipped
# Pricing: 0.05 PLN/req, 0.50 PLN/financial document
REJESTR_IO_API_KEY=

# Optional: Apify API token for social media + reviews scraping
# Without this, falls back to basic curl-based scraping (less data)
# Get token: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# Optional: Meta (Facebook) access token for Ad Library API
# Without this, falls back to scraping public Ad Library page
# Get token: https://developers.facebook.com/tools/explorer/
META_ADS_ACCESS_TOKEN=
