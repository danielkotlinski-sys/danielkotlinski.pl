# Required: Claude API key for extraction (Haiku) and chat/interpret (Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: rejestr.io API key for KRS/financial data
# Without this, the finance phase will be skipped
# Pricing: 0.05 PLN/req, 0.50 PLN/financial document
REJESTR_IO_API_KEY=

# Optional: Apify API token for social media + reviews scraping
# Without this, falls back to basic curl-based scraping (less data)
# Get token: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# Optional: Meta (Facebook) access token for Ad Library API
# Without this, falls back to scraping public Ad Library page
# Get token: https://developers.facebook.com/tools/explorer/
META_ADS_ACCESS_TOKEN=

# Optional: Google Gemini API key for video analysis (IG Reels, TikTok, YouTube reviews)
# Without this, video and youtube_reviews phases will be skipped
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: YouTube Data API v3 key for YouTube review video discovery
# Without this, youtube_reviews phase will be skipped
# Free tier: 10,000 units/day (~100 search queries)
# Get key: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Note: Google Ads Transparency phase uses APIFY_API_TOKEN (above)
# No additional credentials needed — uses madeingermany~google-ads-scraper actor
