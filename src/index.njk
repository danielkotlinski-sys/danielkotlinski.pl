{# ===== BLOG ===== #}
<section class="blog-section">
  <div class="container">
    <div class="blog-section__header reveal">
      <div>
        <p class="section-label">Blog</p>
        <h2>Piszę bloga o strategii marek</h2>
      </div>
    </div>
    <div class="blog-section__grid">
      {%- for post in collections.blog | limit(3) %}
      <a href="{{ post.url | url }}" class="blog-card reveal reveal-delay-{{ loop.index0 + 1 }}">
        {% if post.data.featuredImage %}
        <img src="{{ post.data.featuredImage | url }}" alt="{{ post.data.title }}" class="blog-card__image" loading="lazy">
        {% endif %}
        <div class="blog-card__content">
          <p class="blog-card__date">{{ post.date | dateFormat }}</p>
          <h3 class="blog-card__title">{{ post.data.title }}</h3>
          <span class="blog-card__link">
            Zobacz artykuł
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </div>
      </a>
      {%- endfor %}
    </div>
    <div class="blog-section__footer reveal">
      <a href="{{ '/blog/' | url }}" class="btn btn-teal">Zobacz wszystkie artykuły</a>
    </div>
  </div>
</section>

