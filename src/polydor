<!-- NAV DOTS -->
<nav class="nav" id="nav"></nav>

<script>
const mag=document.getElementById('mag');
const pages=document.querySelectorAll('.page');
const nav=document.getElementById('nav');
const total=pages.length;

// Build dots
for(let i=0;i<total;i++){
  const d=document.createElement('div');
  d.className='dot';
  d.onclick=()=>pages[i].scrollIntoView({behavior:'smooth',inline:'start'});
  nav.appendChild(d);
}
const dots=nav.querySelectorAll('.dot');

function updateDots(){
  const scrollLeft=mag.scrollLeft;
  const w=window.innerWidth;
  const idx=Math.round(scrollLeft/w);
  dots.forEach((d,i)=>d.classList.toggle('active',i===idx));
}

mag.addEventListener('scroll',updateDots);
updateDots();

// Arrow keys
document.addEventListener('keydown',e=>{
  const w=window.innerWidth;
  if(e.key==='ArrowRight')mag.scrollBy({left:w,behavior:'smooth'});
  if(e.key==='ArrowLeft')mag.scrollBy({left:-w,behavior:'smooth'});
});
</script>
