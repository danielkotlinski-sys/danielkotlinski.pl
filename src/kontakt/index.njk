    {# Right column: form in white card #}
    <div class="contact-form-card reveal reveal-delay-1">
      <form class="contact-form" id="contactForm" action="https://formspree.io/f/mjgpyajv" method="POST">
        <div class="form-hp" aria-hidden="true">
          <label>Zostaw to pole puste<input type="text" name="_gotcha" tabindex="-1" autocomplete="off"></label>
        </div>
        <div class="contact-form__group">
          <label for="firstName">Imię</label>
          <input type="text" id="firstName" name="firstName" required placeholder="Twoje imię">
        </div>
        <div class="contact-form__group">
          <label for="lastName">Nazwisko</label>
          <input type="text" id="lastName" name="lastName" required placeholder="Twoje nazwisko">
        </div>
        <div class="contact-form__group">
          <label for="email">Adres email</label>
          <input type="email" id="email" name="email" required placeholder="adres@gmail.com">
        </div>
        <div class="contact-form__group">
          <label for="phone">Numer telefonu</label>
          <input type="tel" id="phone" name="phone" placeholder="Podaj numer...">
        </div>
        <div class="contact-form__group">
          <label for="message">Twoja wiadomość</label>
          <textarea id="message" name="message" required placeholder="Z jakim problemem biznesowym się mierzysz? Opisz krótko — podaj nazwę firmy, link do strony."></textarea>
        </div>
        <button type="submit" class="btn btn-orange btn-full">Wyślij zapytanie</button>
      </form>
      <div class="contact-form-success" id="contactFormSuccess" hidden>
        <h3>Dziękuję za wiadomość!</h3>
        <p>Odezwę się najszybciej jak to możliwe — zwykle w ciągu 24h.</p>
      </div>
